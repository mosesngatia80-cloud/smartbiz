        )
      );

    const data =
      await res.json();

    if (!res.ok) return;

    document.getElementById("todaySales").innerText =
      "KES " + Number(data.todaySales || 0).toLocaleString();

    document.getElementById("weekSales").innerText =
      "KES " + Number(data.weekSales || 0).toLocaleString();

    document.getElementById("monthSales").innerText =
      "KES " + Number(data.monthSales || 0).toLocaleString();

    document.getElementById("yearSales").innerText =
      "KES " + Number(data.yearSales || 0).toLocaleString();

    document.getElementById("salesRevenue").innerText =
      "KES " + Number(data.revenue || 0).toLocaleString();

    document.getElementById("salesGrossProfit").innerText =
      "KES " + Number(data.grossProfit ?? data.revenue ?? 0).toLocaleString();

    document.getElementById("salesNetProfit").innerText =
      "KES " + Number(data.netProfit ?? data.revenue ?? 0).toLocaleString();

    document.getElementById("averageSale").innerText =
      "KES " + Number(data.averageSale || 0).toLocaleString();

    const top =
      document.getElementById("topSellingProducts");

    top.innerHTML = "";

    if (data.topProducts && data.topProducts.length) {

      data.topProducts.forEach(p => {

        top.innerHTML +=
          `<tr><td>${p.name}</td><td>${p.sold}</td></tr>`;

      });

    } else {

      top.innerHTML =
        '<tr><td colspan="2">No sales yet</td></tr>';

    }

    const slow =
      document.getElementById("slowMovingProducts");

    slow.innerHTML = "";

    if (data.slowProducts && data.slowProducts.length) {

      data.slowProducts.forEach(p => {

        slow.innerHTML +=
          `<tr><td>${p.name}</td><td>${p.stock}</td></tr>`;

      });

    } else {

      slow.innerHTML =
        '<tr><td colspan="2">No products</td></tr>';

    }

    const alerts =
      document.getElementById("salesAlerts");

    alerts.innerHTML = "";

    if (data.alerts && data.alerts.length) {

      data.alerts.forEach(a => {

        alerts.innerHTML += `<li>${a}</li>`;

      });

    } else {

      alerts.innerHTML =
        "<li>No alerts.</li>";

    }

    console.log("✅ Sales Analytics loaded.");

  } catch (err) {

    console.error(
      "Sales Analytics error:",
      err
    );

  }

}


