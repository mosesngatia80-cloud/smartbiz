async function loadInventoryLedger() {

  const ledgerBody =
    document.getElementById(
      "ledgerBody"
    );

  if (!ledgerBody) return;

  try {

    const token =
      localStorage.getItem(
        "token"
      );

    const res =
      await fetch(
        API_BASE +
        "/products/inventory-ledger",
        {
          headers: {
            Authorization:
              "Bearer " + token
          }
        }
      );

    const ledger =
      await res.json();

    ledgerBody.innerHTML = "";

    let totalQty = 0;
    let totalBuying = 0;
    let totalSelling = 0;
    let totalProfit = 0;

    let grossProfit = 0;
    let grossLoss = 0;

    ledger.forEach(item => {

      const costPrice =
        Number(
          item.buyingPrice || 0
        );

      const sellingPrice =
        Number(
          item.sellingPrice || 0
        );

      const profit =
        Number(
          item.profitPerUnit || 0
        );

      const rowTotalProfit =
        Number(item.quantity || 0) *
        profit;

      totalQty += Number(item.quantity || 0);
      totalBuying += costPrice * Number(item.quantity || 0);
      totalSelling += sellingPrice * Number(item.quantity || 0);
      totalProfit += rowTotalProfit;

      if (rowTotalProfit >= 0) {
        grossProfit += rowTotalProfit;
      } else {
        grossLoss += Math.abs(rowTotalProfit);
      }

      ledgerBody.innerHTML += `
        <tr>
          <td>${new Date(item.createdAt).toLocaleString()}</td>
          <td>${item.product?.name || "-"}</td>
          <td>${item.action}</td>
          <td>${item.quantity}</td>

          <td>KES ${costPrice.toLocaleString()}</td>
          <td>KES ${sellingPrice.toLocaleString()}</td>
          <td>KES ${profit.toLocaleString()}</td>
          <td>KES ${rowTotalProfit.toLocaleString()}</td>

          <td>${item.stockBefore}</td>
          <td>${item.stockAfter}</td>
        </tr>
      `;
    });

    ledgerBody.innerHTML += `
      <tr style="font-weight:bold;background:#f5f5f5;">
        <td colspan="3">TOTALS</td>
        <td>${totalQty}</td>
        <td>KES ${totalBuying.toLocaleString()}</td>
        <td>KES ${totalSelling.toLocaleString()}</td>
        <td>-</td>
        <td>KES ${totalProfit.toLocaleString()}</td>
        <td>-</td>
        <td>-</td>
      </tr>
    `;

    document.getElementById("grossProfit").innerText =
      "KES " + grossProfit.toLocaleString();

    document.getElementById("grossLoss").innerText =
      "KES " + grossLoss.toLocaleString();

    document.getElementById("netProfit").innerText =
      "KES " + (grossProfit - grossLoss).toLocaleString();

  } catch (err) {

    console.error(err);

  }

}

async function loadProducts() {

  const list =
    document.getElementById(
      "productsList"
    );

  if (!list) return;

  try {

    const business =
      JSON.parse(
        localStorage.getItem(
          "business"
        )
      );

    const res =
      await fetch(

        API_BASE +
        "/products/my-products?whatsappNumber=" +

        encodeURIComponent(
          business.whatsappNumber
        )

      );

    const products =
      await res.json();

    allProducts = products;

    loadInventoryLedger();

    document.getElementById(
      "productsCount"
    ).innerText =
      products.length;

    document.getElementById(
      "lowStockCount"
    ).innerText =
      products.filter(
        p => p.stock > 0 &&
             p.stock <= 5
      ).length;

    document.getElementById(
      "outOfStockCount"
    ).innerText =
      products.filter(
        p => p.stock === 0
      ).length;

    document.getElementById(
      "inventoryValue"
    ).innerText =
      "KES " +
      products.reduce(
        (sum, p) =>
          sum +
          (
            Number(p.costPrice || 0) *
            Number(p.stock || 0)
          ),
        0
      ).toLocaleString();

    const inventoryBody =
      document.getElementById(
        "inventoryBody"
      );

    if (inventoryBody) {

      inventoryBody.innerHTML = "";

      products.forEach(p => {

        const costPrice =
          Number(p.costPrice || 0);

        const sellingPrice =
          Number(
            p.salePrice > 0
              ? p.salePrice
              : p.price
          );

        const stock =
          Number(p.stock || 0);

        const costValue =
          stock * costPrice;

        const salesValue =
          stock * sellingPrice;

        const profitPotential =
          salesValue - costValue;

        inventoryBody.innerHTML += `
          <tr>
            <td>${p.name}</td>
            <td>${p.openingStock || stock}</td>
            <td>${p.stockAdded || 0}</td>
            <td>${p.stockSold || 0}</td>
            <td>${stock}</td>

            <td>
              ${
                costPrice > 0
                ? "KES " + costPrice.toLocaleString()
                : "⚠️ Missing"
              }
            </td>

            <td>KES ${sellingPrice.toLocaleString()}</td>
            <td>KES ${costValue.toLocaleString()}</td>
            <td>KES ${salesValue.toLocaleString()}</td>
            <td>KES ${profitPotential.toLocaleString()}</td>

            <td>
              ${
                stock === 0
                ? "❌ Out Of Stock"
                : stock <= 5
                ? "⚠️ Low Stock"
                : "✅ Normal"
              }
            </td>

          </tr>
        `;
      });

    }

    const debtProduct =
      document.getElementById(
        "debtProduct"
      );

    if (debtProduct) {

      debtProduct.innerHTML =
        '<option value="">Select Product</option>';

      products.forEach(p => {

        debtProduct.innerHTML +=
          `<option value="${p._id}">
            ${p.name}
          </option>`;
      });

    }

    const expenseProduct =
      document.getElementById(
        "expenseProduct"
      );

    if (expenseProduct) {

      expenseProduct.innerHTML =
        '<option value="">Select Product</option>';

      products.forEach(p => {

        expenseProduct.innerHTML +=
          `<option value="${p._id}">
            ${p.name}
          </option>`;
      });

    }

    const cashProduct =
      document.getElementById(
        "cashProduct"
      );

    if (cashProduct) {

      cashProduct.innerHTML =
        '<option value="">Select Product</option>';

      products.forEach(p => {

        cashProduct.innerHTML +=
          `<option value="${p.name}">
            ${p.name}
          </option>`;
      });

    }

    list.innerHTML = "";

    products.forEach(p => {

      const imageUrl =
        p.image
        ? p.image
        : "";

      list.innerHTML += `
        <div class="order-card">

          ${
            p.image
            ? `
              <img
                src="${imageUrl}"
                style="
                  width:100%;
                  max-height:200px;
                  object-fit:cover;
                  border-radius:12px;
                  margin-bottom:10px;
                "
              />
            `
            : ""
          }

          <div>
            <strong>${p.name}</strong>
          </div>

          ${
            p.salePrice > 0 &&
            p.salePrice < p.price
            ? `
              <div>
                <span
                  style="
                    text-decoration:line-through;
                    color:gray;
                  "
                >
                  KES ${Number(p.price || 0).toLocaleString()}
                </span>
              </div>

              <div
                style="
                  font-weight:bold;
                  color:green;
                "
              >
                KES ${Number(p.salePrice || 0).toLocaleString()}
              </div>

              <div
                style="
                  color:red;
                  font-weight:bold;
                "
              >
                ${Math.round(
                  ((p.price - p.salePrice) /
                    p.price) * 100
                )}% OFF
              </div>
            `
            : `
              <div>
                KES ${Number(p.price || 0).toLocaleString()}
              </div>
            `
          }

          <div>
            Stock: ${p.stock}
          </div>

          ${
            p.stock === 0
            ? `
              <div
                style="
                  color:red;
                  font-weight:bold;
                  margin-top:5px;
                "
              >
                ❌ OUT OF STOCK
              </div>
            `
            : p.stock <= 5
            ? `
              <div
                style="
                  color:orange;
                  font-weight:bold;
                  margin-top:5px;
                "
              >
                ⚠️ LOW STOCK
              </div>
            `
            : ""
          }

          <div
            style="
              margin-top:10px;
              display:flex;
              gap:8px;
            "
          >
            <button
              onclick="addStock('${p._id}', ${p.stock})"
            >
              + Stock
            </button>

            <button
              onclick="reduceStock('${p._id}', ${p.stock})"
            >
              - Stock
            </button>

            <button
              onclick="editProduct(
                '${p._id}',
                '${p.name}',
                ${p.costPrice || 0},
                ${p.price},
                ${p.salePrice || 0},
                ${p.stock}
              )"
            >
              Edit
            </button>

            <button
              onclick="deleteProduct('${p._id}')"
            >
              Delete
            </button>
          </div>

        </div>
      `;

    });

  }

  catch (err) {

    console.error(err);

    list.innerHTML =
      "<li>Failed to load products</div>";

  }

}


async function deleteProduct(id) {

  if (!confirm("Delete this product?")) {
    return;
  }

  try {

    const res = await fetch(
      API_BASE + "/products/" + id,
      {
        method: "DELETE"
      }
    );

    const data = await res.json();

    alert(data.message || "Deleted");

    loadProducts();

  } catch (err) {

    console.error(err);

    alert("Failed to delete product");
  }
}

async function updateStock(id, stock) {

  try {

    await fetch(
      API_BASE + "/products/" + id,
      {
        method: "PUT",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          stock
        })
      }
    );

    loadProducts();

  } catch (err) {

    console.error(err);

    alert("Failed to update stock");
  }
}

async function addStock(id, currentStock) {

  const qty =
    Number(
      prompt("Add stock quantity")
    );

  if (!qty) return;

  await updateStock(
    id,
    currentStock + qty
  );
}

async function reduceStock(id, currentStock) {

  const qty =
    Number(
      prompt("Reduce stock quantity")
    );

  if (!qty) return;

  await updateStock(
    id,
    Math.max(
      0,
      currentStock - qty
    )
  );
}


async function editProduct(
  id,
  currentName,
  currentCostPrice,
  currentPrice,
  currentSalePrice,
  currentStock
) {

  const name =
    prompt(
      "Product Name",
      currentName
    );

  if (!name) return;

  const costPrice =
    Number(
      prompt(
        "Buying Price",
        currentCostPrice || 0
      )
    );

  const price =
    Number(
      prompt(
        "Product Price",
        currentPrice
      )
    );

  const salePrice =
    Number(
      prompt(
        "Sale Price (0 = no discount)",
        currentSalePrice || 0
      )
    );

  const stock =
    Number(
      prompt(
        "Product Stock",
        currentStock
      )
    );

  try {

    await fetch(
      API_BASE +
      "/products/" +
      id,
      {
        method: "PUT",
        headers: {
          "Content-Type":
            "application/json"
        },
        body: JSON.stringify({
          name,
          costPrice,
          price,
          salePrice,
          stock
        })
      }
    );

    loadProducts();

  } catch (err) {

    console.error(err);

    alert(
      "Failed to update product"
    );
  }
}


