async function loadBalanceSheet() {

  try {

    const business =
      JSON.parse(
        localStorage.getItem(
          "business"
        )
      );

    if (!business) return;

    const productsRes =
      await fetch(
        API_BASE +
        "/products/my-products?whatsappNumber=" +
        encodeURIComponent(
          business.whatsappNumber
        )
      );

    const products =
      await productsRes.json();


    const inventoryValue =
      products.reduce(
        (sum, p) =>
          sum +
          (
            Number(p.stock || 0) *
            Number(p.costPrice || 0)
          ),
        0
      );

    const expenseRes =
      await fetch(
        API_BASE +
        "/expense?whatsappNumber=" +
        encodeURIComponent(
          business.whatsappNumber
        )
      );

    const expenseData =
      await expenseRes.json();

    const debtRes =
      await fetch(
        API_BASE +
        "/debt?phone=" +
        encodeURIComponent(
          business.whatsappNumber
        )
      );

    const debtData =
      await debtRes.json();

    const walletBalance = 0;

    const dashboardRes =
      await fetch(
        API_BASE +
        "/dashboard/summary?whatsappNumber=" +
        encodeURIComponent(
          business.whatsappNumber
        )
      );

    const dashboardData =
      await dashboardRes.json();

    const serviceRevenue =
      Number(
        dashboardData.serviceRevenue || 0
      );

    const totalAssets =
      inventoryValue +
      Number(
        debtData.totalDebt || 0
      ) +
      walletBalance +
      serviceRevenue;

    const totalLiabilities =
      Number(
        expenseData.totalExpenses || 0
      );

    const netWorth =
      totalAssets -
      totalLiabilities;

    document.getElementById(
      "bsInventoryValue"
    ).innerText =
      "KES " +
      inventoryValue.toLocaleString();


    document.getElementById(
      "bsDebts"
    ).innerText =
      "KES " +
      Number(
        debtData.totalDebt || 0
      ).toLocaleString();

    document.getElementById(
      "bsWallet"
    ).innerText =
      "KES " +
      walletBalance.toLocaleString();

    document.getElementById(
      "bsAssets"
    ).innerText =
      "KES " +
      totalAssets.toLocaleString();

    document.getElementById(
      "bsExpenses"
    ).innerText =
      "KES " +
      totalLiabilities.toLocaleString();

    document.getElementById(
      "bsLiabilities"
    ).innerText =
      "KES " +
      totalLiabilities.toLocaleString();

    document.getElementById(
      "bsNetWorth"
    ).innerText =
      "KES " +
      netWorth.toLocaleString();

  } catch (err) {

    console.error(
      "Balance Sheet Error:",
      err
    );

  }
}


