async function loadOrders() {

  const list =
    document.getElementById(
      "ordersList"
    );

  if (!list) return;

  try {

    const token =
      localStorage.getItem(
        "token"
      );
    const res = await fetch(API_BASE + "/orders", {
      headers: authHeaders()
    });

    const orders = await res.json();



    if (!res.ok) {

      list.innerHTML =
        "<li>Failed to load orders</div>";

      return;
    }

    list.innerHTML = "";

    document.getElementById(
      "totalOrders"
    ).innerText =
      orders.length || 0;
    if (
      typeof window.lastOrderCount === "undefined"
    ) {

      window.lastOrderCount =
        orders.length;

    } else if (
      orders.length >
      window.lastOrderCount
    ) {

      const newOrders =
        orders.length -
        window.lastOrderCount;

      const notification =
        document.getElementById(
          "orderNotification"
        );

      if (notification) {

        notification.innerText =
          "🔔 " +
          newOrders +
          " New Order" +
          (newOrders > 1 ? "s" : "");

        notification.style.display =
          "block";

        setTimeout(() => {

          notification.style.display =
            "none";

        }, 5000);
      }

      window.lastOrderCount =
        orders.length;

    } else {

      window.lastOrderCount =
        orders.length;
    }

    const paid =
      orders.filter(
        o => o.status === "PAID"
      ).length;

    const pending =
      orders.filter(
        o => o.status === "PENDING"
      ).length;

    document.getElementById(
      "paidOrders"
    ).innerText = paid;

    document.getElementById(
      "pendingOrders"
    ).innerText = pending;

    orders.forEach(order => {

      const items =
        order.items
          ?.map(i =>
            `${i.name} x${i.qty}`
          )
          .join(", ");

      const created =
        new Date(
          order.createdAt
        ).toLocaleString();

      list.innerHTML += `

        <div class="order-card">

          <div>
